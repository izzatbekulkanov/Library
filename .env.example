# ==============================
# App runtime
# ==============================
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8001
APP_WORKERS=3
APP_TIMEOUT=120
APP_GRACEFUL_TIMEOUT=30
ROOT_PATH=

# ==============================
# Security
# ==============================
# Majburiy: productionda uzun maxfiy kalit bering.
APP_SESSION_SECRET_KEY=change-this-to-a-long-random-secret
APP_SESSION_COOKIE=proadmin_session
APP_SESSION_MAX_AGE=1800
APP_SESSION_SAME_SITE=lax
APP_SESSION_HTTPS_ONLY=true
APP_SESSION_DOMAIN=
APP_TRUSTED_HOSTS=library.example.com,www.library.example.com
APP_FORCE_HTTPS=false

# API docs (productionda odatda false)
APP_ENABLE_DOCS=false
APP_ENABLE_REDOC=false

# ==============================
# DB config file paths
# ==============================
# Tizim db parametrlari shu fayllarda saqlanadi.
APP_DB_CONFIG_PATH=app/core/db_config.json
APP_SYSTEM_SETTINGS_PATH=app/core/system_settings.json
