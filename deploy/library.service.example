[Unit]
Description=Library FastAPI Application
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/library
EnvironmentFile=/opt/library/.env
ExecStart=/bin/bash /opt/library/scripts/start_prod.sh
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
